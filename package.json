{
  "name": "pi-monitor",
  "version": "0.1.0",
  "description": "Background, monitor, loop, and schedule jobs for the pi coding agent, with idle-aware session notifications.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "background-jobs",
    "monitoring",
    "notifications"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "0.79.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0"
  }
}
